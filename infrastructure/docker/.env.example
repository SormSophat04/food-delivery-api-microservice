# Database Configuration
DB_URL=jdbc:postgresql://postgres:5432/food_delivery
DB_USERNAME=postgres
DB_PASSWORD=pg12345
JPA_DDL_AUTO=update

# MongoDB Configuration
MONGODB_HOST_NAME=mongo
SPRING_DATA_MONGODB_URI=mongodb://mongo:27017/delivery_service_db

# JWT Configuration
JWT_SECRET=replace-with-secure-secret
JWT_ISSUER=food-delivery-api
JWT_EXPIRATION_MS=86400000

# OAuth2 Configuration
OAUTH2_CLIENT_ID_WEB=food-delivery-web
OAUTH2_CLIENT_SECRET_WEB={noop}secret-web
OAUTH2_CLIENT_ID_MOBILE=food-delivery-mobile
OAUTH2_CLIENT_SECRET_MOBILE={noop}secret-mobile
OAUTH2_REDIRECT_URI_WEB=http://localhost:3000/login/oauth2/code/food-delivery
OAUTH2_REDIRECT_URI_MOBILE=fooddelivery://oauth2/callback
OAUTH2_ACCESS_TOKEN_TTL=30
OAUTH2_REFRESH_TOKEN_TTL=1440

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=noreply@food-delivery.local
MAIL_BRAND_NAME=Food Delivery

# OTP Configuration
OTP_LENGTH=6
OTP_TTL_MINUTES=10

# Kafka Configuration
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Spring Profiles
SPRING_PROFILES_ACTIVE=docker
